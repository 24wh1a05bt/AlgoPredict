// ─── MARKET LIST ───
function renderMarketList(filter = 'all') {
  const list = document.getElementById('market-list');
  const filtered = filter === 'all' ? MARKETS : MARKETS.filter(m => m.category === filter);
  document.getElementById('market-count').textContent = filtered.length;
  list.innerHTML = filtered.map(m => `
    <div class="market-item ${m.id === activeMarket.id ? 'active' : ''}" onclick="setActiveMarket(MARKETS.find(x=>x.id===${m.id}))">
      <div class="market-item-name">${m.name}</div>
      <div class="market-item-meta">
        <span class="market-category">${m.category}</span>
        <span class="market-volume">Vol: <span>${m.vol.toLocaleString()}</span></span>
      </div>
      <div class="prob-bar"><div class="prob-fill" style="width:${m.yes}%"></div></div>
      <div class="prob-labels">
        <span class="yes-label">YES ${m.yes}¢</span>
        <span class="no-label">NO ${100 - m.yes}¢</span>
      </div>
    </div>
  `).join('');
}

function filterMarkets(cat, btn) {
  filterActive = cat;
  document.querySelectorAll('.filter-chip').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  renderMarketList(cat);
}

function setActiveMarket(m) {
  activeMarket = m;
  document.getElementById('active-market-title').textContent = m.name;
  document.getElementById('yes-price').textContent = `¢${m.yes}`;
  document.getElementById('no-price').textContent = `¢${100 - m.yes}`;
  document.getElementById('app-id').textContent = m.appId.slice(0, 8) + '...';
  document.getElementById('resolves').textContent = m.resolves;
  document.getElementById('volume').textContent = m.vol.toLocaleString();
  document.getElementById('liquidity').textContent = Math.floor(m.vol * 0.38).toLocaleString();
  document.getElementById('best-price-hint').textContent = `Best Ask: ${(m.yes + 0.4).toFixed(1)}¢`;
  document.getElementById('price-input').value = m.yes;
  updateSummary();
  renderMarketList(filterActive);
  renderOrderBook();
  initChart();
  renderRecentTrades();
  updateSubmitBtn();
}

// ─── TICKER ───
function renderTicker() {
  const track = document.getElementById('ticker-track');
  const items = [...MARKETS, ...MARKETS].map(m => `
    <div class="ticker-item">
      <span class="name">${m.name.slice(0, 36)}${m.name.length > 36 ? '…' : ''}</span>
      <span class="yes-price">YES ${m.yes}¢</span>
      <span class="no-price">NO ${100 - m.yes}¢</span>
    </div>
  `).join('');
  track.innerHTML = items;
}

// ─── CHART ───
function initChart() {
  const container = document.getElementById('price-chart');
  container.innerHTML = '';
  if (priceChart) { priceChart.remove(); priceChart = null; }

  priceChart = LightweightCharts.createChart(container, {
    width: container.clientWidth,
    height: container.clientHeight,
    layout: {
      background: { type: 'solid', color: '#050508' },
      textColor: '#8888a8',
      fontFamily: "'JetBrains Mono', monospace",
      fontSize: 11,
    },
    grid: {
      vertLines: { color: 'rgba(255,255,255,0.04)' },
      horzLines: { color: 'rgba(255,255,255,0.04)' },
    },
    crosshair: {
      mode: LightweightCharts.CrosshairMode.Normal,
      vertLine: { color: 'rgba(0,229,180,0.4)', style: 1, labelBackgroundColor: '#0c0c14' },
      horzLine: { color: 'rgba(0,229,180,0.4)', style: 1, labelBackgroundColor: '#0c0c14' },
    },
    rightPriceScale: {
      borderColor: 'rgba(255,255,255,0.07)',
      scaleMargins: { top: 0.1, bottom: 0.1 },
    },
    timeScale: {
      borderColor: 'rgba(255,255,255,0.07)',
      timeVisible: true,
      secondsVisible: false,
    },
  });

  priceSeries = priceChart.addAreaSeries({
    lineColor: activeTradeTab === 'yes' ? '#00e5b4' : '#ff6b6b',
    topColor: activeTradeTab === 'yes' ? 'rgba(0,229,180,0.18)' : 'rgba(255,107,107,0.18)',
    bottomColor: 'rgba(0,0,0,0)',
    lineWidth: 2,
    crosshairMarkerVisible: true,
    crosshairMarkerRadius: 4,
    crosshairMarkerBackgroundColor: '#050508',
  });

  const data = generateChartData(activeMarket.yes);
  priceSeries.setData(data);
  priceChart.timeScale().fitContent();

  window.addEventListener('resize', () => {
    if (priceChart) {
      priceChart.applyOptions({
        width: container.clientWidth,
        height: container.clientHeight,
      });
    }
  });
}

function generateChartData(currentPrice) {
  const data = [];
  const now = Math.floor(Date.now() / 1000);
  let price = currentPrice * 0.7 + Math.random() * 5;
  for (let i = 720; i >= 0; i--) {
    price += (Math.random() - 0.47) * 1.8;
    price = Math.max(5, Math.min(95, price));
    if (i < 50) price += (currentPrice - price) * 0.05;
    data.push({ time: now - i * 300, value: +price.toFixed(2) });
  }
  return data;
}

// ─── ORDERBOOK ───
function renderOrderBook() {
  const asks = document.getElementById('ob-asks');
  const bids = document.getElementById('ob-bids');
  const midP = activeMarket.yes;
  const askRows = [];
  const bidRows = [];

  let totalAsk = 0, totalBid = 0;
  for (let i = 9; i >= 0; i--) {
    const price = (midP + 0.4 + i * 0.4 + Math.random() * 0.2).toFixed(1);
    const size = Math.floor(Math.random() * 3000 + 200);
    totalAsk += size;
    askRows.push({ price, size, total: totalAsk });
  }
  for (let i = 0; i < 10; i++) {
    const price = (midP - 0.4 - i * 0.4 - Math.random() * 0.2).toFixed(1);
    const size = Math.floor(Math.random() * 3000 + 200);
    totalBid += size;
    bidRows.push({ price, size, total: totalBid });
  }

  const maxAsk = Math.max(...askRows.map(r => r.total));
  const maxBid = Math.max(...bidRows.map(r => r.total));

  asks.innerHTML = askRows.map(r => `
    <div class="ob-row ob-ask" onclick="document.getElementById('price-input').value=${r.price};updateSummary()">
      <span>${r.price}</span>
      <span style="text-align:center">${r.size.toLocaleString()}</span>
      <span style="text-align:right">${r.total.toLocaleString()}</span>
      <div class="depth-bar" style="width:${(r.total/maxAsk*100).toFixed(1)}%"></div>
    </div>
  `).join('');

  bids.innerHTML = bidRows.map(r => `
    <div class="ob-row ob-bid" onclick="document.getElementById('price-input').value=${r.price};updateSummary()">
      <span>${r.price}</span>
      <span style="text-align:center">${r.size.toLocaleString()}</span>
      <span style="text-align:right">${r.total.toLocaleString()}</span>
      <div class="depth-bar" style="width:${(r.total/maxBid*100).toFixed(1)}%"></div>
    </div>
  `).join('');

  document.getElementById('spread-val').textContent = '0.8¢';
  document.getElementById('mid-price').textContent = `${midP.toFixed(1)}¢`;
}

// ─── RECENT TRADES ───
const tradeLog = [];
function renderRecentTrades() {
  const container = document.getElementById('recent-trades');
  const sides = ['yes', 'yes', 'yes', 'no', 'yes', 'no', 'no', 'yes', 'no', 'yes', 'yes', 'no'];
  tradeLog.length = 0;
  for (let i = 0; i < 18; i++) {
    const side = sides[i % sides.length];
    const price = (activeMarket.yes + (Math.random() - 0.5) * 3).toFixed(1);
    const size = Math.floor(Math.random() * 800 + 50);
    tradeLog.push({ side, price, size });
  }
  renderTradeList();
}

function renderTradeList() {
  const container = document.getElementById('recent-trades');
  container.innerHTML = tradeLog.map(t => `
    <div class="trade-row ${t.side}">
      <span>${t.side.toUpperCase()}</span>
      <span style="text-align:center">${t.price}¢</span>
      <span>${t.size}</span>
    </div>
  `).join('');
}

// ─── POSITIONS ───
function renderPositions() {
  const list = document.getElementById('pos-list');
  const positions = [
    { market: "BTC > $70K Jun 30", side: "yes", size: 250, entry: 58.2, mark: 64.0, pnl: "+14.50", pct: "+9.97%" },
    { market: "Fed Rate Cut Jul", side: "no", size: 400, entry: 54.8, mark: 53.0, pnl: "+7.20", pct: "+3.28%" },
  ];
  list.innerHTML = positions.map(p => `
    <div class="pos-row">
      <span class="pos-market">${p.market}</span>
      <span class="pos-side ${p.side}">${p.side.toUpperCase()}</span>
      <span style="text-align:right">${p.size}</span>
      <span style="text-align:right">${p.entry}¢</span>
      <span style="text-align:right">${p.mark}¢</span>
