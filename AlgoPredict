  { id: 9, name: "Will SOL surpass ETH in market cap by 2026?", category: "crypto", yes: 29, vol: 67800, appId: "1088727200", resolves: "210d 0h" },
  { id: 10, name: "Gold above $2,500 by July 31?", category: "politics", yes: 58, vol: 114300, appId: "1088727310", resolves: "55d 18h" },
  { id: 11, name: "Will Apple release AR glasses in 2025?", category: "politics", yes: 44, vol: 231000, appId: "1088727420", resolves: "150d 0h" },
  { id: 12, name: "Man City win 2024-25 Champions League?", category: "sports", yes: 26, vol: 178000, appId: "1088727530", resolves: "40d 0h" },
