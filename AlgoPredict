  .modal {
    background: var(--surface);
    border: 1px solid var(--border-bright);
    border-radius: 8px;
    padding: 28px;
    width: 360px;
    transform: translateY(10px);
    transition: transform 0.2s;
  }
  .modal-overlay.show .modal { transform: translateY(0); }
