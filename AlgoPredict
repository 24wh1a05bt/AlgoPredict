<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>ORACLE — Algorand Prediction Markets</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/lightweight-charts/4.1.3/lightweight-charts.standalone.production.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Syne:wght@400;500;600;700;800&family=JetBrains+Mono:wght@300;400;500;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #050508;
    --surface: #0c0c14;
    --surface2: #12121e;
    --surface3: #1a1a2e;
    --border: rgba(255,255,255,0.07);
    --border-bright: rgba(255,255,255,0.14);
    --accent: #00e5b4;
    --accent2: #7b5ea7;
    --accent3: #ff6b6b;
    --yes: #00e5b4;
    --no: #ff6b6b;
    --text: #f0f0f8;
    --text2: #8888a8;
    --text3: #4a4a6a;
    --glow: 0 0 30px rgba(0,229,180,0.15);
    --font-head: 'Syne', sans-serif;
    --font-mono: 'JetBrains Mono', monospace;
  }

  * { margin: 0; padding: 0; box-sizing: border-box; }

  body {
    background: var(--bg);
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    line-height: 1.6;
    overflow-x: hidden;
    min-height: 100vh;
  }

  /* Noise overlay */
  body::before {
    content: '';
    position: fixed;
    inset: 0;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.04'/%3E%3C/svg%3E");
    pointer-events: none;
    z-index: 9999;
    opacity: 0.4;
  }

  /* Grid background */
  body::after {
    content: '';
    position: fixed;
    inset: 0;
    background-image:
      linear-gradient(rgba(0,229,180,0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0,229,180,0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    pointer-events: none;
    z-index: 0;
  }

  /* ─── LAYOUT ─── */
  .app { position: relative; z-index: 1; display: flex; flex-direction: column; min-height: 100vh; }

  /* ─── TOPBAR ─── */
  .topbar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    padding: 0 24px;
    height: 56px;
    border-bottom: 1px solid var(--border);
    background: rgba(5,5,8,0.9);
    backdrop-filter: blur(20px);
    position: sticky;
    top: 0;
    z-index: 100;
  }

  .logo {
    font-family: var(--font-head);
    font-size: 20px;
    font-weight: 800;
    letter-spacing: 0.12em;
    color: var(--text);
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .logo-dot {
    width: 8px; height: 8px;
    border-radius: 50%;
    background: var(--accent);
    box-shadow: 0 0 12px var(--accent);
    animation: pulse 2s ease-in-out infinite;
  }

  .nav {
    display: flex;
    gap: 2px;
  }
  .nav-btn {
    background: none;
    border: none;
    color: var(--text2);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.08em;
    padding: 6px 14px;
    cursor: pointer;
    border-radius: 4px;
    transition: all 0.2s;
    text-transform: uppercase;
  }
  .nav-btn:hover, .nav-btn.active { color: var(--text); background: var(--surface2); }
  .nav-btn.active { color: var(--accent); }

  .topbar-right {
    display: flex;
    align-items: center;
    gap: 12px;
  }

  .algo-price {
    font-size: 11px;
    color: var(--text2);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .algo-price span { color: var(--accent); font-weight: 500; }

  .connect-btn {
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    padding: 7px 18px;
    border-radius: 4px;
    cursor: pointer;
    text-transform: uppercase;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .connect-btn::before {
    content: '';
    position: absolute;
    inset: 0;
    background: var(--accent);
    transform: translateX(-100%);
    transition: transform 0.2s;
  }
  .connect-btn:hover::before { transform: translateX(0); }
  .connect-btn:hover { color: var(--bg); }
  .connect-btn span { position: relative; z-index: 1; }
  .connect-btn.connected {
    border-color: var(--accent);
    color: var(--bg);
    background: var(--accent);
  }

  /* ─── TICKER ─── */
  .ticker-bar {
    height: 32px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    overflow: hidden;
    display: flex;
    align-items: center;
  }
  .ticker-track {
    display: flex;
    gap: 0;
    animation: ticker 35s linear infinite;
    white-space: nowrap;
  }
  .ticker-item {
    display: flex;
    align-items: center;
    gap: 8px;
    padding: 0 24px;
    font-size: 11px;
    color: var(--text2);
    border-right: 1px solid var(--border);
  }
  .ticker-item .name { color: var(--text); font-weight: 500; }
  .ticker-item .yes-price { color: var(--yes); }
  .ticker-item .no-price { color: var(--no); }

  @keyframes ticker {
    from { transform: translateX(0); }
    to { transform: translateX(-50%); }
  }

  /* ─── MAIN GRID ─── */
  .main {
    display: grid;
    grid-template-columns: 280px 1fr 320px;
    flex: 1;
    height: calc(100vh - 88px);
    overflow: hidden;
  }

  /* ─── LEFT SIDEBAR ─── */
  .sidebar-left {
    border-right: 1px solid var(--border);
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--surface3) transparent;
  }
  .sidebar-left::-webkit-scrollbar { width: 4px; }
  .sidebar-left::-webkit-scrollbar-track { background: transparent; }
  .sidebar-left::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 2px; }

  .section-header {
    padding: 14px 16px 10px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 10;
  }
  .section-title {
    font-family: var(--font-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text2);
  }
  .count-badge {
    font-size: 10px;
    color: var(--text3);
    background: var(--surface2);
    padding: 1px 6px;
    border-radius: 2px;
  }

  .filter-row {
    padding: 8px 12px;
    display: flex;
    gap: 4px;
    border-bottom: 1px solid var(--border);
  }
  .filter-chip {
    font-family: var(--font-mono);
    font-size: 10px;
    padding: 3px 8px;
    border-radius: 3px;
    border: 1px solid var(--border);
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
    letter-spacing: 0.05em;
  }
  .filter-chip:hover { border-color: var(--border-bright); color: var(--text); }
  .filter-chip.active { border-color: var(--accent); color: var(--accent); background: rgba(0,229,180,0.08); }

  .market-list { padding: 8px 0; }

  .market-item {
    padding: 10px 16px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    transition: background 0.15s;
    position: relative;
  }
  .market-item:hover { background: var(--surface); }
  .market-item.active { background: var(--surface2); }
  .market-item.active::before {
    content: '';
    position: absolute;
    left: 0; top: 0; bottom: 0;
    width: 2px;
    background: var(--accent);
  }

  .market-item-name {
    font-family: var(--font-head);
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 6px;
    line-height: 1.4;
  }
  .market-item-meta {
    display: flex;
    align-items: center;
    justify-content: space-between;
    margin-bottom: 6px;
  }
  .market-category {
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text3);
    background: var(--surface3);
    padding: 2px 6px;
    border-radius: 2px;
  }
  .market-volume {
    font-size: 10px;
    color: var(--text2);
  }
  .market-volume span { color: var(--text); }

  .prob-bar {
    height: 3px;
    background: var(--surface3);
    border-radius: 2px;
    overflow: hidden;
    margin-bottom: 4px;
  }
  .prob-fill {
    height: 100%;
    border-radius: 2px;
    background: linear-gradient(90deg, var(--yes), rgba(0,229,180,0.5));
    transition: width 0.5s ease;
  }
  .prob-labels {
    display: flex;
    justify-content: space-between;
    font-size: 10px;
  }
  .yes-label { color: var(--yes); }
  .no-label { color: var(--no); }

  /* ─── CENTER ─── */
  .center-panel {
    display: flex;
    flex-direction: column;
    overflow: hidden;
  }

  .market-header {
    padding: 16px 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .market-title-row {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 12px;
  }
  .market-title {
    font-family: var(--font-head);
    font-size: 18px;
    font-weight: 700;
    color: var(--text);
    max-width: 600px;
    line-height: 1.3;
  }
  .market-status {
    display: flex;
    align-items: center;
    gap: 6px;
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent);
    background: rgba(0,229,180,0.08);
    border: 1px solid rgba(0,229,180,0.2);
    padding: 4px 10px;
    border-radius: 3px;
    white-space: nowrap;
  }
  .status-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent);
    animation: pulse 1.5s ease-in-out infinite;
  }

  .market-stats {
    display: flex;
    gap: 32px;
  }
  .stat-item { }
  .stat-label {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 2px;
  }
  .stat-value {
    font-size: 16px;
    font-weight: 700;
    color: var(--text);
  }
  .stat-value.yes { color: var(--yes); }
  .stat-value.no { color: var(--no); }
  .stat-change {
    font-size: 10px;
    color: var(--text3);
    margin-top: 1px;
  }
  .stat-change.up { color: var(--yes); }
  .stat-change.down { color: var(--no); }

  /* Chart tabs */
  .chart-tabs {
    display: flex;
    gap: 0;
    padding: 0 24px;
    border-bottom: 1px solid var(--border);
    background: var(--surface);
  }
  .chart-tab {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 14px;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: -1px;
  }
  .chart-tab:hover { color: var(--text); }
  .chart-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .chart-container {
    flex: 1;
    position: relative;
    overflow: hidden;
  }
  #price-chart {
    width: 100%;
    height: 100%;
  }

  /* Orderbook */
  .orderbook-panel {
    display: none;
    flex-direction: column;
    overflow: hidden;
    height: 100%;
  }
  .orderbook-panel.active { display: flex; }

  .ob-header {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 8px 24px;
    font-size: 9px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
  }
  .ob-header span:last-child, .ob-row span:last-child { text-align: right; }

  .ob-asks, .ob-bids {
    overflow-y: auto;
    flex: 1;
    scrollbar-width: none;
  }
  .ob-asks::-webkit-scrollbar, .ob-bids::-webkit-scrollbar { display: none; }

  .ob-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 4px 24px;
    font-size: 11px;
    position: relative;
    cursor: pointer;
    transition: background 0.1s;
  }
  .ob-row:hover { background: var(--surface2); }
  .ob-row .depth-bar {
    position: absolute;
    top: 0; bottom: 0;
    right: 0;
    opacity: 0.08;
    pointer-events: none;
    transition: width 0.3s;
  }
  .ob-ask .depth-bar { background: var(--no); }
  .ob-bid .depth-bar { background: var(--yes); }
  .ob-ask span:first-child { color: var(--no); }
  .ob-bid span:first-child { color: var(--yes); }

  .ob-spread {
    padding: 6px 24px;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 12px;
    border-top: 1px solid var(--border);
    border-bottom: 1px solid var(--border);
    background: var(--surface);
    font-size: 11px;
  }
  .spread-label { color: var(--text3); font-size: 10px; letter-spacing: 0.1em; text-transform: uppercase; }
  .spread-value { color: var(--text); font-weight: 500; }
  .mid-price { color: var(--accent); font-size: 14px; font-weight: 700; }

  /* ─── RIGHT SIDEBAR ─── */
  .sidebar-right {
    border-left: 1px solid var(--border);
    display: flex;
    flex-direction: column;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: var(--surface3) transparent;
  }
  .sidebar-right::-webkit-scrollbar { width: 4px; }
  .sidebar-right::-webkit-scrollbar-thumb { background: var(--surface3); border-radius: 2px; }

  /* Trade form */
  .trade-form {
    padding: 16px;
    border-bottom: 1px solid var(--border);
  }
  .trade-tabs {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 0;
    margin-bottom: 14px;
    border: 1px solid var(--border);
    border-radius: 4px;
    overflow: hidden;
  }
  .trade-tab {
    padding: 8px;
    border: none;
    background: var(--surface);
    color: var(--text2);
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
  }
  .trade-tab.yes.active { background: rgba(0,229,180,0.15); color: var(--yes); }
  .trade-tab.no.active { background: rgba(255,107,107,0.15); color: var(--no); }
  .trade-tab:hover:not(.active) { background: var(--surface2); color: var(--text); }

  .order-type-row {
    display: flex;
    gap: 4px;
    margin-bottom: 14px;
  }
  .order-type-btn {
    flex: 1;
    padding: 5px;
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.08em;
    text-transform: uppercase;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
  }
  .order-type-btn.active { border-color: var(--accent2); color: var(--accent2); background: rgba(123,94,167,0.1); }
  .order-type-btn:hover:not(.active) { color: var(--text); border-color: var(--border-bright); }

  .form-group { margin-bottom: 12px; }
  .form-label {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 5px;
    display: flex;
    justify-content: space-between;
    align-items: center;
  }
  .form-label .hint { color: var(--text2); font-size: 10px; letter-spacing: 0; text-transform: none; }
  .form-input {
    width: 100%;
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 9px 12px;
    color: var(--text);
    font-family: var(--font-mono);
    font-size: 13px;
    outline: none;
    transition: border-color 0.2s;
  }
  .form-input:focus { border-color: var(--accent); }
  .form-input::placeholder { color: var(--text3); }

  .input-with-addon {
    position: relative;
  }
  .input-addon {
    position: absolute;
    right: 12px;
    top: 50%;
    transform: translateY(-50%);
    font-size: 11px;
    color: var(--text2);
    pointer-events: none;
  }

  .slider-row {
    display: flex;
    gap: 4px;
    margin-bottom: 12px;
  }
  .slider-btn {
    flex: 1;
    padding: 5px 0;
    font-family: var(--font-mono);
    font-size: 10px;
    border: 1px solid var(--border);
    border-radius: 3px;
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
    text-align: center;
  }
  .slider-btn:hover { border-color: var(--border-bright); color: var(--text); }

  .order-summary {
    background: var(--surface2);
    border: 1px solid var(--border);
    border-radius: 4px;
    padding: 10px 12px;
    margin-bottom: 14px;
  }
  .summary-row {
    display: flex;
    justify-content: space-between;
    font-size: 11px;
    margin-bottom: 4px;
  }
  .summary-row:last-child { margin-bottom: 0; }
  .summary-row .key { color: var(--text2); }
  .summary-row .val { color: var(--text); }
  .summary-row.total .key, .summary-row.total .val {
    color: var(--accent);
    font-weight: 700;
    font-size: 12px;
  }

  .submit-btn {
    width: 100%;
    padding: 12px;
    border: none;
    border-radius: 4px;
    font-family: var(--font-head);
    font-size: 13px;
    font-weight: 700;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    cursor: pointer;
    transition: all 0.2s;
    position: relative;
    overflow: hidden;
  }
  .submit-btn.yes {
    background: var(--yes);
    color: var(--bg);
  }
  .submit-btn.no {
    background: var(--no);
    color: var(--text);
  }
  .submit-btn:hover { filter: brightness(1.1); transform: translateY(-1px); }
  .submit-btn:active { transform: translateY(0); }

  /* Recent trades */
  .trades-section { padding: 0; flex: 1; }
  .trades-header {
    padding: 12px 16px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
  }
  .trades-title {
    font-family: var(--font-head);
    font-size: 10px;
    font-weight: 700;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text2);
  }

  .trade-cols {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 6px 16px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
  }
  .trade-cols span:last-child { text-align: right; }

  .trade-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    padding: 5px 16px;
    font-size: 11px;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    animation: fadeSlideIn 0.3s ease;
  }
  .trade-row span:last-child { text-align: right; color: var(--text2); font-size: 10px; }
  .trade-row.yes span:first-child { color: var(--yes); }
  .trade-row.no span:first-child { color: var(--no); }

  /* ─── POSITION PANEL ─── */
  .positions-bar {
    border-top: 1px solid var(--border);
    height: 160px;
    display: flex;
    flex-direction: column;
    background: var(--surface);
  }
  .pos-tabs {
    display: flex;
    padding: 0 16px;
    border-bottom: 1px solid var(--border);
  }
  .pos-tab {
    font-family: var(--font-mono);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    padding: 8px 14px;
    border: none;
    border-bottom: 2px solid transparent;
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.2s;
    margin-bottom: -1px;
  }
  .pos-tab:hover { color: var(--text); }
  .pos-tab.active { color: var(--accent); border-bottom-color: var(--accent); }

  .pos-cols {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr 1fr;
    padding: 6px 16px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--text3);
    border-bottom: 1px solid var(--border);
  }
  .pos-cols span:not(:first-child), .pos-row span:not(:first-child) { text-align: right; }

  .pos-list { overflow-y: auto; flex: 1; scrollbar-width: none; }
  .pos-list::-webkit-scrollbar { display: none; }

  .pos-row {
    display: grid;
    grid-template-columns: 2fr 1fr 1fr 1fr 1fr 1fr 1fr;
    padding: 7px 16px;
    font-size: 11px;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    align-items: center;
  }
  .pos-row:hover { background: var(--surface2); }
  .pos-market { color: var(--text); font-size: 11px; }
