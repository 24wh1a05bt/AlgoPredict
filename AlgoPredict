    display: flex;
    gap: 20px;
  }
  .oracle-item { display: flex; align-items: center; gap: 6px; }
  .oracle-name { color: var(--text2); }
  .oracle-val { color: var(--text); font-weight: 500; }
  .oracle-src { color: var(--text3); font-size: 9px; }

  /* ─── ANIMATIONS ─── */
  @keyframes pulse {
    0%, 100% { opacity: 1; }
    50% { opacity: 0.4; }
  }
  @keyframes fadeSlideIn {
    from { opacity: 0; transform: translateY(-4px); }
    to { opacity: 1; transform: translateY(0); }
  }
  @keyframes shimmer {
    0% { background-position: -200% 0; }
    100% { background-position: 200% 0; }
  }

  /* ─── MODAL ─── */
  .modal-overlay {
    position: fixed;
    inset: 0;
    background: rgba(5,5,8,0.85);
    backdrop-filter: blur(8px);
    z-index: 1000;
    display: flex;
    align-items: center;
    justify-content: center;
    opacity: 0;
    pointer-events: none;
    transition: opacity 0.2s;
