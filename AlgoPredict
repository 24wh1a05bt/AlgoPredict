// ─── TRADE FORM ───
function setTradeTab(tab) {
  activeTradeTab = tab;
  document.getElementById('yes-tab').classList.toggle('active', tab === 'yes');
  document.getElementById('no-tab').classList.toggle('active', tab === 'no');
  updateSubmitBtn();
  updateSummary();
  if (priceChart) initChart();
}

function setOrderType(btn, type) {
  orderType = type;
  document.querySelectorAll('.order-type-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
  const priceGroup = document.getElementById('price-group');
  priceGroup.style.display = type === 'market' ? 'none' : 'block';
  updateSummary();
}

function updateSubmitBtn() {
  const btn = document.getElementById('submit-btn');
  const label = document.getElementById('submit-label');
  if (!walletConnected) {
    btn.className = 'submit-btn yes';
    btn.style.background = 'var(--surface3)';
    btn.style.color = 'var(--text2)';
    label.textContent = 'Connect Wallet to Trade';
    return;
  }
  if (activeTradeTab === 'yes') {
    btn.className = 'submit-btn yes';
    btn.style.background = '';
    btn.style.color = '';
    label.textContent = 'Place Buy YES Order';
  } else {
    btn.className = 'submit-btn no';
    btn.style.background = '';
    btn.style.color = '';
    label.textContent = 'Place Buy NO Order';
  }
}

function updateSummary() {
  const price = parseFloat(document.getElementById('price-input').value) || activeMarket.yes;
  const size = parseFloat(document.getElementById('size-input').value) || 0;
  const shares = size > 0 ? (size / price * 100).toFixed(2) : '0.00';
  const potential = size > 0 ? (parseFloat(shares) - size).toFixed(2) : '0.00';
  const fee = (size * 0.0025).toFixed(2);
  const total = (size + parseFloat(fee)).toFixed(2);

  document.getElementById('sum-shares').textContent = shares;
  document.getElementById('sum-price').textContent = `${price.toFixed(1)}¢`;
  document.getElementById('sum-return').textContent = `+${potential} ALGO`;
  document.getElementById('sum-return').style.color = parseFloat(potential) >= 0 ? 'var(--yes)' : 'var(--no)';
  document.getElementById('sum-fee').textContent = `${fee} ALGO`;
  document.getElementById('sum-total').textContent = `${total} ALGO`;
}

function setPct(pct) {
  const bal = walletConnected ? 1250 : 0;
  if (!walletConnected) { openWalletModal(); return; }
  document.getElementById('size-input').value = Math.floor(bal * pct / 100);
  updateSummary();
}

function submitOrder() {
  if (!walletConnected) { openWalletModal(); return; }
  const price = parseFloat(document.getElementById('price-input').value);
  const size = parseFloat(document.getElementById('size-input').value);
  if (!size || size <= 0) { showNotif('error', 'Invalid Order', 'Please enter a valid order size.'); return; }

  showNotif('success', 'Order Submitted', `Buy ${activeTradeTab.toUpperCase()} @ ${price.toFixed(1)}¢ for ${size} ALGO — Awaiting blockchain confirmation.`);

  // Add fake trade to log
  tradeLog.unshift({ side: activeTradeTab, price: price.toFixed(1), size: Math.floor(size / price * 100) });
  if (tradeLog.length > 20) tradeLog.pop();
  renderTradeList();
}

// ─── CHART TABS ───
function setChartTab(tab, btn) {
  activeChartTab = tab;
  document.querySelectorAll('.chart-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');

  document.getElementById('chart-panel').style.display = tab === 'chart' ? 'flex' : 'none';
  document.getElementById('orderbook-panel').classList.toggle('active', tab === 'orderbook');
  document.getElementById('depth-panel').style.display = tab === 'depth' ? 'flex' : 'none';
  document.getElementById('info-panel').style.display = tab === 'info' ? 'block' : 'none';

  if (tab === 'chart') { setTimeout(() => initChart(), 50); }
  if (tab === 'depth') { renderDepthChart(); }
}

function renderDepthChart() {
  const container = document.getElementById('depth-chart');
  container.innerHTML = '';
  const chart = LightweightCharts.createChart(container, {
    width: container.clientWidth,
    height: container.clientHeight,
    layout: { background: { type: 'solid', color: '#050508' }, textColor: '#8888a8', fontFamily: "'JetBrains Mono', monospace", fontSize: 11 },
    grid: { vertLines: { color: 'rgba(255,255,255,0.04)' }, horzLines: { color: 'rgba(255,255,255,0.04)' } },
    rightPriceScale: { borderColor: 'rgba(255,255,255,0.07)' },
    timeScale: { visible: false },
  });

  const askSeries = chart.addAreaSeries({ lineColor: '#ff6b6b', topColor: 'rgba(255,107,107,0.2)', bottomColor: 'rgba(0,0,0,0)', lineWidth: 1.5 });
  const bidSeries = chart.addAreaSeries({ lineColor: '#00e5b4', topColor: 'rgba(0,229,180,0.2)', bottomColor: 'rgba(0,0,0,0)', lineWidth: 1.5 });

  const mid = activeMarket.yes;
  const askData = Array.from({length: 20}, (_, i) => ({ time: i + 1, value: (i + 1) * 400 + Math.random() * 200 }));
  const bidData = Array.from({length: 20}, (_, i) => ({ time: i + 1, value: (20 - i) * 380 + Math.random() * 200 }));
  askSeries.setData(askData);
  bidSeries.setData(bidData);
  chart.timeScale().fitContent();
}

// ─── POS TABS ───
function setPosTab(btn, tab) {
  document.querySelectorAll('.pos-tab').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ─── WALLET ───
function openWalletModal() {
  document.getElementById('wallet-modal').classList.add('show');
}
function closeWalletModal() {
  document.getElementById('wallet-modal').classList.remove('show');
}

function connectWallet(type) {
  closeWalletModal();
  walletConnected = true;
  walletAddress = 'ALGO' + Math.random().toString(36).substr(2, 6).toUpperCase() + '...K3QT';
  document.getElementById('connect-btn').classList.add('connected');
  document.getElementById('connect-label').textContent = walletAddress;
  document.getElementById('balance-hint').textContent = 'Bal: 1,250 ALGO';
  updateSubmitBtn();
  showNotif('success', 'Wallet Connected', `${type.charAt(0).toUpperCase() + type.slice(1)} connected successfully.`);
}

// ─── NOTIFICATIONS ───
function showNotif(type, title, msg) {
  const n = document.getElementById('notif');
  document.getElementById('notif-icon').textContent = type === 'success' ? '✓' : '✕';
  document.getElementById('notif-title').textContent = title;
  document.getElementById('notif-msg').textContent = msg;
  n.className = `notif ${type} show`;
  setTimeout(() => n.classList.remove('show'), 4000);
}

// ─── NAV ───
function setNav(btn, tab) {
  document.querySelectorAll('.nav-btn').forEach(b => b.classList.remove('active'));
  btn.classList.add('active');
}

// ─── LIVE UPDATES ───
function startLiveUpdates() {
  // Oracle prices
  setInterval(() => {
    const btc = 67240 + (Math.random() - 0.5) * 800;
    const eth = 3512 + (Math.random() - 0.5) * 80;
    const algo = 0.1834 + (Math.random() - 0.5) * 0.004;
    document.getElementById('of-btc').textContent = `$${btc.toLocaleString('en',{maximumFractionDigits:0})}`;
    document.getElementById('of-eth').textContent = `$${eth.toLocaleString('en',{maximumFractionDigits:0})}`;
    document.getElementById('of-algo').textContent = `$${algo.toFixed(4)}`;
    document.getElementById('algo-usd').textContent = `$${algo.toFixed(4)}`;
  }, 3000);

  // Price chart live tick
  setInterval(() => {
    if (priceSeries && activeChartTab === 'chart') {
      const yesPrice = parseFloat(document.getElementById('yes-price').textContent.replace('¢',''));
      const newPrice = Math.max(5, Math.min(95, yesPrice + (Math.random() - 0.48) * 0.6));
      const roundedPrice = parseFloat(newPrice.toFixed(2));
      document.getElementById('yes-price').textContent = `¢${roundedPrice.toFixed(1)}`;
      document.getElementById('no-price').textContent = `¢${(100 - roundedPrice).toFixed(1)}`;
      activeMarket.yes = roundedPrice;

      try {
        priceSeries.update({ time: Math.floor(Date.now() / 1000), value: roundedPrice });
      } catch(e) {}
    }
  }, 2000);

  // New trade every few seconds
  setInterval(() => {
    const sides = ['yes', 'no'];
    const side = sides[Math.floor(Math.random() * 2)];
    const price = (activeMarket.yes + (Math.random() - 0.5) * 2).toFixed(1);
    const size = Math.floor(Math.random() * 500 + 50);
    tradeLog.unshift({ side, price, size });
    if (tradeLog.length > 20) tradeLog.pop();
    renderTradeList();
  }, 1800);

  // Orderbook refresh
  setInterval(() => {
    if (activeChartTab === 'orderbook') renderOrderBook();
  }, 2500);
}

// Close modal on overlay click
document.getElementById('wallet-modal').addEventListener('click', function(e) {
  if (e.target === this) closeWalletModal();
});
</script>
