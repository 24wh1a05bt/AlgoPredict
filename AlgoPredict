    border-radius: 2px;
    background: none;
    color: var(--text2);
    cursor: pointer;
    transition: all 0.15s;
    text-align: right;
  }
  .close-btn:hover { border-color: var(--no); color: var(--no); }

  /* ─── ORACLE FEED ─── */
  .oracle-band {
    background: var(--surface2);
    border-bottom: 1px solid var(--border);
    padding: 8px 24px;
    display: flex;
    align-items: center;
    gap: 24px;
    font-size: 10px;
  }
  .oracle-label {
    font-size: 9px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: var(--text3);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .oracle-dot {
    width: 5px; height: 5px;
    border-radius: 50%;
    background: var(--accent2);
    box-shadow: 0 0 8px var(--accent2);
    animation: pulse 2s ease-in-out infinite 0.5s;
  }
